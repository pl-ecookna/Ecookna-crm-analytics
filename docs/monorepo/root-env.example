# Shared
NODE_ENV=development

# Web
VITE_API_BASE_URL=http://localhost:3000

# API
PORT=3000
CRM_WEBHOOK_PATH=/webhook/getcrmdata
CRM_WEBHOOK_MAX_FILE_AGE_DAYS=30

DB_MAIN_URL=postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require
DB_DISAPPROVE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_REGION=ru1
S3_BUCKET=<bucket>
S3_ACCESS_KEY_ID=<access_key>
S3_SECRET_ACCESS_KEY=<secret_key>

SBER_AUTH_KEY=<base64_basic_auth>
SBER_SCOPE=SALUTE_SPEECH_PERS
SBER_MODEL=callcenter
SBER_INSIGHT_MODELS=csi,call_features
SBER_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
SBER_UPLOAD_URL=https://smartspeech.sber.ru/rest/v1/data:upload
SBER_RECOGNIZE_URL=https://smartspeech.sber.ru/rest/v1/speech:async_recognize
SBER_TASK_URL=https://smartspeech.sber.ru/rest/v1/task:get
SBER_DOWNLOAD_URL=https://smartspeech.sber.ru/rest/v1/data:download
SBER_SAMPLE_RATE=
SBER_CHANNELS_COUNT=

DEEPGRAM_API_KEY=<deepgram_token>
OPENAI_API_KEY=<openai_key>
OPENAI_MODEL=gpt-4o

CRON_ENABLED=false
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=15000
CRON_MAIN=*/10 * * * *
CRON_DISAPPROVE=45 * * * *
MAIN_BATCH_LIMIT=150
DISAPPROVE_BATCH_LIMIT=200
MIN_CALL_DURATION_SECONDS=60
